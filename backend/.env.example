PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:4000
# Use real PostgreSQL by default:
DATABASE_URL=postgres://postgres:postgres@localhost:5432/cufcai_learn
# For managed online PostgreSQL (Neon, Supabase, Railway, Render), set:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require
# DB_SSL_MODE=require
# For quick local testing without PostgreSQL installed, use:
# DATABASE_URL=pgmem://local
DB_SSL_MODE=disable
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=2h
COOKIE_NAME=cufcai_auth
LOCKOUT_ATTEMPTS=5
LOCKOUT_MINUTES=15
